{
  "name": "super-barber",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:check": "node --env-file=.env.local scripts/check-db.mjs",
    "db:schema": "node --env-file=.env.local scripts/run-sql.mjs database/schema.sql",
